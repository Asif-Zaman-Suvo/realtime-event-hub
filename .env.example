# Local development
#
# api (host → compose postgres is mapped to 5433):
#   DATABASE_URL=postgres://events:events@localhost:5433/events
#   REDIS_URL=redis://localhost:6379
#
# worker: same as api
#
# dashboard (Vite):
#   VITE_API_URL=http://localhost:3000
#   VITE_WS_URL=ws://localhost:3000

DATABASE_URL=postgres://events:events@localhost:5433/events
REDIS_URL=redis://localhost:6379
REDIS_STREAM_KEY=events:stream
REDIS_CONSUMER_GROUP=persist-workers
REDIS_METRICS_CHANNEL=events:metrics

NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

WORKER_NAME=worker-1
WORKER_BATCH_SIZE=500
WORKER_FLUSH_MS=3000
WORKER_BLOCK_MS=5000

VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
